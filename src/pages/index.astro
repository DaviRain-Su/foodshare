---
import Layout from '../layouts/Layout.astro';
import { Feed } from '../components/Feed';
import { NavBar } from '../components/NavBar';
import { getAuthUser } from '../lib/auth';
import { env } from 'cloudflare:workers';

const userId = await getAuthUser(Astro.request, env.JWT_SECRET);
---

<Layout title="FoodShare">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-lg mx-auto px-4 h-12 flex items-center">
      <h1 class="text-lg font-bold text-orange-500">FoodShare</h1>
    </div>
  </header>

  <main class="max-w-lg mx-auto p-4 pb-20">
    <Feed client:load currentUserId={userId ?? undefined} />
  </main>

  <NavBar client:load />
</Layout>
