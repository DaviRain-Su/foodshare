---
import Layout from '../layouts/Layout.astro';
import { Settings } from '../components/Settings';
import { NavBar } from '../components/NavBar';
---

<Layout title="Settings - FoodShare">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-lg mx-auto px-4 h-12 flex items-center">
      <a href="/" class="text-gray-500 hover:text-gray-700 mr-3">&larr;</a>
      <h1 class="text-lg font-bold">Settings</h1>
    </div>
  </header>

  <main class="max-w-lg mx-auto p-4 pb-20">
    <Settings client:load />
  </main>

  <NavBar client:load />
</Layout>
