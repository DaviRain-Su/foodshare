---
import Layout from '../../layouts/Layout.astro';
import { PostDetail } from '../../components/PostDetail';
import { NavBar } from '../../components/NavBar';
import { getAuthUser } from '../../lib/auth';
import { env } from 'cloudflare:workers';

const { id } = Astro.params;
const userId = await getAuthUser(Astro.request, env.JWT_SECRET);
---

<Layout title="Post - FoodShare">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-lg mx-auto px-4 h-12 flex items-center">
      <a href="/" class="text-gray-500 hover:text-gray-700 mr-3">&larr;</a>
      <h1 class="text-lg font-bold">Post</h1>
    </div>
  </header>

  <main class="pb-20">
    <PostDetail client:load postId={id!} currentUserId={userId ?? undefined} />
  </main>

  <NavBar client:load />
</Layout>
