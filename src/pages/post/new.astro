---
import Layout from '../../layouts/Layout.astro';
import { CreatePost } from '../../components/CreatePost';
import { NavBar } from '../../components/NavBar';
import { getAuthUser } from '../../lib/auth';
import { env } from 'cloudflare:workers';

const userId = await getAuthUser(Astro.request, env.JWT_SECRET);
if (!userId) return Astro.redirect('/login');
---

<Layout title="New Post - FoodShare">
  <header class="bg-paper/90 backdrop-blur-md border-b border-ink/8 sticky top-0 z-40">
    <div class="max-w-lg mx-auto px-4 h-12 flex items-center">
      <a href="/feed" class="text-ink-4 hover:text-ink-2 mr-3">&larr;</a>
      <h1 class="text-lg font-display text-ink">New Post</h1>
    </div>
  </header>

  <main class="max-w-lg mx-auto p-4 pb-20">
    <CreatePost client:load />
  </main>

  <NavBar client:load />
</Layout>
